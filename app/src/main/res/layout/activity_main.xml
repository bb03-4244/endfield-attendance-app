<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 로그인된 계정 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="로그인된 계정"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="로그인이 필요합니다."
                android:textSize="16sp"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/txtUserSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="로그인 후 자동출석과 수동출석을 사용할 수 있습니다."
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- 버튼 영역 -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="로그인하기"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnCheckIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="수동 출석체크"
            android:layout_marginBottom="12dp" />

        <!-- 이성 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/imgSanity"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_sanity"
                android:scaleType="centerInside" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/txtSanityTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="이성"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#111111" />

                <TextView
                    android:id="@+id/txtSanityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="값 준비 중"
                    android:textSize="16sp"
                    android:layout_marginTop="6dp"
                    android:textColor="#111111" />

                <TextView
                    android:id="@+id/txtSanitySub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="최대 이성과 회복 시간은 추후 연결"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:textColor="#666666" />
            </LinearLayout>
        </LinearLayout>

        <!-- 출석 결과 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="출석 결과"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/txtResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="아직 실행되지 않음"
                android:textSize="15sp"
                android:textColor="#111111" />

            <!-- 오늘 보상 영역 -->
            <LinearLayout
                android:id="@+id/layoutReward"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imgReward"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerInside"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/txtRewardLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="오늘 보상"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#666666" />

                    <TextView
                        android:id="@+id/txtReward"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="보상 정보"
                        android:textSize="16sp"
                        android:textColor="#111111" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>